{
  "name": "fastline-rental",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && npm run generate:sitemap && npm run generate:robots && npm run prerender",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "generate:robots": "tsx scripts/generate-robots.ts",
    "prerender": "tsx scripts/prerender.ts",
    "verify:seo": "tsx scripts/verify-seo.ts",
    "verify:a11y": "tsx scripts/verify-a11y.ts",
    "analyze": "vite-bundle-visualizer --open"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.76.0",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.5.0",
    "axe-playwright": "^2.2.0",
    "eslint": "^9.39.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.4.0",
    "vite-bundle-visualizer": "^1.2.0",
    "vite-imagetools": "^7.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-prerender": "^1.0.0",
    "vitest": "^3.2.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  }
}
